generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  isSubscriber Boolean       @default(false)
  createdAt    DateTime      @default(now())
  pedidos      Pedido[]
  assinatura   Assinatura?
}

model Jogo {
  id          Int          @id @default(autoincrement())
  title       String
  category    String
  console     String
  description String
  imageUrl    String
  price       Float
  releaseYear Int
  stock       Int          @default(0)
  itensPedido ItemPedido[]
}

model Pedido {
  id            Int          @id @default(autoincrement())
  usuarioId     Int
  total         Float
  status        String       @default("Aguardando entrega")
  paymentMethod String
  createdAt     DateTime     @default(now())
  usuario       Usuario      @relation(fields: [usuarioId], references: [id])
  items         ItemPedido[]
}

model ItemPedido {
  id       Int    @id @default(autoincrement())
  pedidoId Int
  jogoId   Int
  quantity Int    @default(1)
  price    Float
  pedido   Pedido @relation(fields: [pedidoId], references: [id])
  jogo     Jogo   @relation(fields: [jogoId], references: [id])
}

model Assinatura {
  id            Int      @id @default(autoincrement())
  usuarioId     Int      @unique
  plan          String
  status        String
  startDate     DateTime
  endDate       DateTime
  paymentMethod String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])
}
